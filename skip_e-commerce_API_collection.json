            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"seller01\",\n    \"email\": \"seller01@example.com\",\n    \"password\": \"password123\",\n    \"fullName\": \"John Seller\",\n    \"role\": \"ROLE_SELLER\",\n    \"address\": \"123 Seller Street\",\n    \"phoneNumber\": \"1234567890\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a seller account. Expected: 201 Created."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n    \"success\": true,\n    \"message\": \"User registered successfully\",\n    \"data\": {\n        \"token\": \"eyJhbGciOiJIUzM4...\",\n        \"tokenType\": \"Bearer\",\n        \"username\": \"seller01\",\n        \"email\": \"seller01@example.com\",\n        \"role\": \"ROLE_SELLER\"\n    },\n    \"timestamp\": \"2025-01-01T10:00:00\"\n}"
