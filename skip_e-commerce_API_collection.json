    {
      "name": "8G — Orders",
      "item": [
        {
          "name": "Place an Order (Buyer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.environment.set(\"order_id\", json.data.id);",
                  "console.log(\"Order ID saved:\", json.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{buyer_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"items\": [\n        {\n            \"productId\": {{product_id}},\n            \"quantity\": 2\n        }\n    ],\n    \"shippingAddress\": \"456 Buyer Avenue, New York, NY 10001\",\n    \"paymentMethod\": \"CREDIT_CARD\",\n    \"notes\": \"Please deliver between 9am and 5pm\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"]
            },
            "description": "Place a single-item order. Requires buyer token and `product_id`. Auto-saves `order_id`. After running, verify stock decreased by checking GET /api/products/{{product_id}}."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n    \"success\": true,\n    \"message\": \"Order placed successfully\",\n    \"data\": {\n        \"id\": 1,\n        \"buyerUsername\": \"buyer01\",\n        \"status\": \"PENDING\",\n        \"totalAmount\": 1999.98,\n        \"shippingAddress\": \"456 Buyer Avenue...\",\n        \"orderItems\": [\n            {\n                \"productName\": \"iPhone 15 Pro Max\",\n                \"quantity\": 2,\n                \"unitPrice\": 1099.99,\n                \"subTotal\": 2199.98\n            }\n        ]\n    }\n}"
            }
          ]
        },
