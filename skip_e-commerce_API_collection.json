    {
      "name": "8D — Categories (Admin only)",
      "item": [
        {
          "name": "Create Parent Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.environment.set(\"category_id\", json.data.id);",
                  "console.log(\"Category ID saved:\", json.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Electronics\",\n    \"description\": \"Electronic devices and accessories\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "categories"]
            },
            "description": "Create a parent category. Requires admin token. Auto-saves `category_id`. Expected: 201 Created."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n    \"success\": true,\n    \"message\": \"Category created successfully\",\n    \"data\": {\n        \"id\": 1,\n        \"name\": \"Electronics\",\n        \"description\": \"Electronic devices and accessories\",\n        \"parentId\": null,\n        \"parentName\": null,\n        \"subCategories\": []\n    }\n}"
            }
          ]
        },
        {
          "name": "Create Sub-Category (Smartphones)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Smartphones\",\n    \"description\": \"Mobile phones and smartphones\",\n    \"parentId\": {{category_id}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "categories"]
            },
            "description": "Create a sub-category nested under Electronics. Requires admin token and `category_id`."
          },
          "response": []
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "categories"]
            },
            "description": "Fetch all categories. Public endpoint. Should show Electronics with Smartphones nested as a sub-category."
          },
          "response": []
        },
        {
          "name": "Get Top-Level Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/categories/top-level",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", "top-level"]
            },
            "description": "Returns only root-level categories. Public endpoint. Should return only Electronics, not Smartphones."
          },
          "response": []
        }
      ]
